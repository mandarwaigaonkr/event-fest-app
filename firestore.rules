rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isSafeUserCreate(uid) {
      return isOwner(uid) &&
        request.resource.data.uid == uid &&
        request.resource.data.role == 'user';
    }
    function isSafeUserUpdate(uid) {
      return isOwner(uid) &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.role == resource.data.role;
    }
    function isSafeRegistrationCreate(uid) {
      return isOwner(uid) &&
        request.resource.data.uid == uid &&
        request.resource.data.banned == false &&
        request.resource.data.attendance == 'not_marked' &&
        request.resource.data.status in ['registered', 'waitlisted'] &&
        request.resource.data.keys().hasOnly([
          'uid',
          'name',
          'email',
          'regNumber',
          'class',
          'department',
          'registeredAt',
          'attendance',
          'attendanceMarkedAt',
          'banned',
          'status',
          'teamId'
        ]);
    }
    function counterValue(field) {
      return resource.data.keys().hasAny([field]) ? resource.data[field] : 0;
    }
    function isValidCounterStep(field) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([field]) ||
        (request.resource.data[field] is int &&
         request.resource.data[field] >= 0 &&
         (request.resource.data[field] == counterValue(field) + 1 ||
          request.resource.data[field] == counterValue(field) - 1));
    }
    function isUserCounterUpdateOnly() {
      return isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'registeredCount',
          'waitlistCount',
          'registeredTeamsCount',
          'waitlistTeamsCount'
        ]) &&
        isValidCounterStep('registeredCount') &&
        isValidCounterStep('waitlistCount') &&
        isValidCounterStep('registeredTeamsCount') &&
        isValidCounterStep('waitlistTeamsCount');
    }
    function isTeamUpdateFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'members',
        'invitedUids',
        'memberUids',
        'status'
      ]);
    }
    function canLeaderManageTeam() {
      return isSignedIn() &&
        request.auth.uid == resource.data.leaderUid &&
        isTeamUpdateFieldsOnly();
    }
    function canInvitedUserRespondToTeam() {
      return isSignedIn() &&
        request.auth.uid in resource.data.invitedUids &&
        !(request.auth.uid in request.resource.data.invitedUids) &&
        isTeamUpdateFieldsOnly();
    }
    function canMemberLeaveTeam() {
      return isSignedIn() &&
        request.auth.uid in resource.data.memberUids &&
        !(request.auth.uid in request.resource.data.memberUids) &&
        isTeamUpdateFieldsOnly();
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSafeUserCreate(uid);
      allow update: if isAdmin() || isSafeUserUpdate(uid);
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      // Allow admins full update, allow users to update ONLY registeredCount, waitlistCount, registeredTeamsCount, waitlistTeamsCount
      allow update: if isAdmin() || isUserCounterUpdateOnly();

      match /registrations/{uid} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isSafeRegistrationCreate(uid);
        allow update: if isAdmin();
        allow delete: if isOwner(uid) || isAdmin();
      }

      match /teams/{teamId} {
        allow read: if isAdmin() || (isSignedIn() && (request.auth.uid in resource.data.invitedUids || request.auth.uid in resource.data.memberUids));
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.leaderUid;
        // Leaders can invite/cancel; invited users can accept/decline; members can leave.
        allow update: if isAdmin() || canLeaderManageTeam() || canInvitedUserRespondToTeam() || canMemberLeaveTeam();
        allow delete: if isAdmin();
      }
    }

    // Collection group rule for teams — needed for Dashboard invite notifications
    // This allows querying teams across all events where user is invited/member
    match /{path=**}/teams/{teamId} {
      allow read: if isAdmin() || (isSignedIn() && (request.auth.uid in resource.data.invitedUids || request.auth.uid in resource.data.memberUids));
    }

    // Collection group rule for registrations — needed for user dashboards without
    // reading every event document first.
    match /{path=**}/registrations/{uid} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
    }
  }
}
