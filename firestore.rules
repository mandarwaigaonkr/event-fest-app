rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      // Allow admins full update, allow users to update ONLY registeredCount, waitlistCount, registeredTeamsCount, waitlistTeamsCount
      allow update: if isAdmin() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['registeredCount', 'waitlistCount', 'registeredTeamsCount', 'waitlistTeamsCount']));

      match /registrations/{uid} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid);
        allow update: if isAdmin();
        allow delete: if isOwner(uid) || isAdmin();
      }

      match /teams/{teamId} {
        allow read: if isAdmin() || (isSignedIn() && (request.auth.uid in resource.data.invitedUids || request.auth.uid in resource.data.memberUids));
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.leaderUid;
        // Allow invited users or existing members to update the team (e.g. accepting an invite)
        allow update: if isAdmin() || (isSignedIn() && (request.auth.uid in resource.data.invitedUids || request.auth.uid in resource.data.memberUids));
        allow delete: if isAdmin();
      }
    }

    // Collection group rule for teams — needed for Dashboard invite notifications
    // This allows querying teams across all events where user is invited/member
    match /{path=**}/teams/{teamId} {
      allow read: if isAdmin() || (isSignedIn() && (request.auth.uid in resource.data.invitedUids || request.auth.uid in resource.data.memberUids));
    }
  }
}
