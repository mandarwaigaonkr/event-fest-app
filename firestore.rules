rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isSafeUserCreate(uid) {
      return isOwner(uid) &&
        request.resource.data.uid == uid &&
        request.resource.data.role == 'user' &&
        request.auth.token.email.matches('.*christuniversity\\.in');
    }
    function isSafeUserUpdate(uid) {
      return isOwner(uid) &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.role == resource.data.role;
    }
    function isSafeRegistrationCreate(uid) {
      return isOwner(uid) &&
        request.resource.data.uid == uid &&
        request.resource.data.banned == false &&
        request.resource.data.attendance == 'not_marked' &&
        request.resource.data.status in ['registered', 'waitlisted'] &&
        request.resource.data.keys().hasOnly([
          'uid',
          'name',
          'email',
          'regNumber',
          'class',
          'department',
          'registeredAt',
          'attendance',
          'attendanceMarkedAt',
          'banned',
          'status',
          'teamId'
        ]);
    }
    function counterValue(field) {
      return resource.data.keys().hasAny([field]) ? resource.data[field] : 0;
    }
    function isValidCounterStep(field) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([field]) ||
        (request.resource.data[field] is int &&
         request.resource.data[field] >= 0 &&
         (request.resource.data[field] == counterValue(field) + 1 ||
          request.resource.data[field] == counterValue(field) - 1));
    }
    // Counter updates are only allowed when the user's registration state is
    // CHANGING in the same transaction (creating or deleting their own registration).
    // existsAfter() sees the state after all writes in the transaction complete,
    // so exists() != existsAfter() proves a registration is being created or deleted.
    function isUserCounterUpdateOnly(eventId) {
      return isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'registeredCount',
          'waitlistCount',
          'registeredTeamsCount',
          'waitlistTeamsCount'
        ]) &&
        isValidCounterStep('registeredCount') &&
        isValidCounterStep('waitlistCount') &&
        isValidCounterStep('registeredTeamsCount') &&
        isValidCounterStep('waitlistTeamsCount') &&
        (exists(/databases/$(database)/documents/events/$(eventId)/registrations/$(request.auth.uid)) !=
         existsAfter(/databases/$(database)/documents/events/$(eventId)/registrations/$(request.auth.uid)));
    }

    // Leader can update members, invitedUids, and status — but NOT memberUids.
    // Status must be a valid value.
    function canLeaderManageTeam() {
      return isSignedIn() &&
        request.auth.uid == resource.data.leaderUid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'members',
          'invitedUids',
          'status'
        ]) &&
        request.resource.data.status in ['incomplete', 'valid', 'cancelled'];
    }
    // Invited user can respond (accept/decline). They remove themselves from
    // invitedUids and may add to memberUids. Status must stay valid.
    function canInvitedUserRespondToTeam() {
      return isSignedIn() &&
        request.auth.uid in resource.data.invitedUids &&
        !(request.auth.uid in request.resource.data.invitedUids) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'members',
          'invitedUids',
          'memberUids',
          'status'
        ]) &&
        request.resource.data.status in ['incomplete', 'valid', 'cancelled'];
    }
    // Member can leave. They remove themselves from memberUids.
    function canMemberLeaveTeam() {
      return isSignedIn() &&
        request.auth.uid in resource.data.memberUids &&
        !(request.auth.uid in request.resource.data.memberUids) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'members',
          'invitedUids',
          'memberUids',
          'status'
        ]) &&
        request.resource.data.status in ['incomplete', 'valid', 'cancelled'];
    }
    function isSafeNotificationCreate(uid) {
      return isSignedIn() &&
        request.resource.data.recipientUid == uid &&
        request.resource.data.actorUid == request.auth.uid &&
        request.resource.data.read == false &&
        request.resource.data.keys().hasOnly([
          'type',
          'title',
          'message',
          'link',
          'eventId',
          'teamId',
          'actorUid',
          'actorName',
          'recipientUid',
          'read',
          'createdAt'
        ]) &&
        request.resource.data.type in [
          'team_invite_accepted',
          'team_invite_rejected',
          'event_update',
          'admin_notice'
        ];
    }
    function isSafeNotificationReadUpdate(uid) {
      return isOwner(uid) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'read',
          'readAt'
        ]) &&
        request.resource.data.read == true;
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSafeUserCreate(uid);
      allow update: if isAdmin() || isSafeUserUpdate(uid);
      allow delete: if isAdmin();

      match /notifications/{notificationId} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isSafeNotificationCreate(uid) || isAdmin();
        allow update: if isSafeNotificationReadUpdate(uid) || isAdmin();
        allow delete: if isOwner(uid) || isAdmin();
      }
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      // Allow admins full update; users can ONLY update counters AND only
      // when their own registration is being created/deleted in the same transaction.
      allow update: if isAdmin() || isUserCounterUpdateOnly(eventId);

      match /registrations/{uid} {
        allow read: if isSignedIn();
        allow create: if isSafeRegistrationCreate(uid);
        allow update: if isAdmin();
        allow delete: if isOwner(uid) || isAdmin();
      }

      match /teams/{teamId} {
        allow read: if isAdmin() || (isSignedIn() && (request.auth.uid in resource.data.invitedUids || request.auth.uid in resource.data.memberUids));
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.leaderUid;
        // Leaders can invite/cancel; invited users can accept/decline; members can leave.
        allow update: if isAdmin() || canLeaderManageTeam() || canInvitedUserRespondToTeam() || canMemberLeaveTeam();
        allow delete: if isAdmin();
      }
    }

    // Collection group rule for teams — needed for Dashboard invite notifications
    // This allows querying teams across all events where user is invited/member
    match /{path=**}/teams/{teamId} {
      allow read: if isAdmin() || (isSignedIn() && (request.auth.uid in resource.data.invitedUids || request.auth.uid in resource.data.memberUids));
    }

    // Collection group rule for registrations — needed for user dashboards without
    // reading every event document first.
    match /{path=**}/registrations/{uid} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
    }
  }
}
